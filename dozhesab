                { id: "sefuroks", label: "Sefuroks 125mg/5ml (Sefuroksim)", min: 10, max: 15, conc: 125, freq: 2, tType: "daily", note: "Günde 2 defa (12 saat arayla)" },
                { id: "cefaks", label: "Cefaks 125mg/5ml (Sefuroksim)", min: 10, max: 15, conc: 125, freq: 2, tType: "daily", note: "Günde 2 defa (12 saat arayla)" },
                { id: "cleocin", label: "Cleocin Pediatrik 75mg/5ml (Klindamisin)", min: 10, max: 30, conc: 75, freq: 3, tType: "daily", note: "Günde 3 defa (8 saat arayla)" },
                { id: "azitro", label: "Azitro 200mg/5ml (Azitromisin)", min: 10, max: 10, conc: 200, freq: 1, tType: "daily", note: "Günde sadece 1 kez (Aç karna önerilir)" }
            ],
            analgesic: [
                { id: "calpol", label: "Calpol Süsp. 125mg/5ml (Parasetamol)", min: 10, max: 15, conc: 125, freq: 4, tType: "per_dose", note: "Ağrı veya ateş durumunda, 4-6 saatte bir", gapHours: "4-6" },
                { id: "parol", label: "Parol Süsp. 250mg/5ml (Parasetamol)", min: 10, max: 15, conc: 250, freq: 4, tType: "per_dose", note: "Ağrı veya ateş durumunda, 4-6 saatte bir", gapHours: "4-6" },
                { id: "dolven", label: "Dolven Süsp. 100mg/5ml (İbuprofen)", min: 4, max: 10, conc: 100, freq: 3, tType: "per_dose", note: "Ağrı veya ateş durumunda, tok karnına, 6-8 saatte bir", gapHours: "6-8" },
                { id: "pedifen", label: "Pedifen Süsp. 100mg/5ml (İbuprofen)", min: 4, max: 10, conc: 100, freq: 3, tType: "per_dose", note: "Ağrı veya ateş durumunda, tok karnına, 6-8 saatte bir", gapHours: "6-8" },
                { id: "ibufen", label: "Ibufen Süsp. 100mg/5ml (İbuprofen)", min: 4, max: 10, conc: 100, freq: 3, tType: "per_dose", note: "Ağrı veya ateş durumunda, tok karnına, 6-8 saatte bir", gapHours: "6-8" }
            ]
        };

        let currentTab = "antibiotic";

        window.onload = function() {
            initModule();
        };

        // Sekme Değiştirme
        function switchTab(tabId) {
            currentTab = tabId;
            document.getElementById('tab-btn-antibiotic').className = "flex-1 md:flex-none px-5 py-2.5 text-xs font-bold rounded-lg transition-all flex items-center justify-center gap-2 " + (tabId === 'antibiotic' ? 'active-tab' : 'text-slate-600 hover:text-slate-800');
            document.getElementById('tab-btn-analgesic').className = "flex-1 md:flex-none px-5 py-2.5 text-xs font-bold rounded-lg transition-all flex items-center justify-center gap-2 " + (tabId === 'analgesic' ? 'active-tab' : 'text-slate-600 hover:text-slate-800');
            
            initModule();
        }

        // Modülü yükle
        function initModule() {
            const select = document.getElementById('drug-select');
            select.innerHTML = "";
            
            DB[currentTab].forEach(drug => {
                const opt = document.createElement('option');
                opt.value = drug.id;
                opt.innerText = drug.label;
                select.appendChild(opt);
            });

            onDrugChange();
        }

        // İlaç Seçimi Değiştiğinde
        function onDrugChange() {
            const select = document.getElementById('drug-select');
            const selectedId = select.value;
            const drug = DB[currentTab].find(d => d.id === selectedId);

            if(!drug) return;

            const slider = document.getElementById('target-dose-slider');
            slider.min = drug.min;
            slider.max = drug.max;
            slider.value = drug.max;
            
            document.getElementById('dose-label').innerText = drug.tType === 'daily' ? 'Günlük Hedef Doz (mg/kg/gün)' : 'Seferlik Dozaj (mg/kg/doz)';
            document.getElementById('dose-range-badge').innerText = `${drug.min} - ${drug.max} mg/kg`;
            document.getElementById('target-dose-val').innerText = slider.value;

            if (drug.tType === 'daily') {
                document.getElementById('result-mg-title').innerText = "Günlük Toplam Doz";
                document.getElementById('result-mg-desc').innerText = "24 Saatteki Toplam mg";
                document.getElementById('result-freq-title').innerText = "Günde Kaç Defa?";
            } else {
                document.getElementById('result-mg-title').innerText = "Seferlik Doz";
                document.getElementById('result-mg-desc').innerText = "Tek Seferde Alınacak mg";
                document.getElementById('result-freq-title').innerText = "Önerilen Aralık";
            }

            runCalculation();
        }

        // Slider tetiklendiğinde
        function onSliderMove() {
            const slider = document.getElementById('target-dose-slider');
            document.getElementById('target-dose-val').innerText = slider.value;
            runCalculation();
        }

        // Dozaj Hesaplayıcı Motor
        function runCalculation() {
            const weight = parseFloat(document.getElementById('weight').value) || 15;
            const selectedId = document.getElementById('drug-select').value;
            const drug = DB[currentTab].find(d => d.id === selectedId);

            if (!drug) return;

            const targetDose = parseFloat(document.getElementById('target-dose-slider').value);

            let totalMg, singleMg, singleMl, freqText, freqDescText;

            if (drug.tType === "daily") {
                totalMg = weight * targetDose;
                singleMg = totalMg / drug.freq;
                singleMl = (singleMg / drug.conc) * 5;
                freqText = `${drug.freq} Sefer`;
                freqDescText = `${Math.round(24/drug.freq)} Saatte Bir`;
            } else {
                singleMg = weight * targetDose;
                totalMg = singleMg; 
                singleMl = (singleMg / drug.conc) * 5;
                freqText = `${drug.gapHours} Saat`;
                freqDescText = `İhtiyaç Halinde`;
            }

            const roundedMl = Math.round(singleMl * 10) / 10;

            document.getElementById('res-mg').innerText = `${Math.round(totalMg)} mg`;
            document.getElementById('res-freq').innerText = freqText;
            document.getElementById('res-freq-desc').innerText = freqDescText;
            document.getElementById('res-ml').innerText = `${roundedMl} ml`;
            document.getElementById('res-ml-sub').innerText = `${Math.round(singleMg)} mg aktif madde`;

            document.getElementById('out-prep-name').innerText = drug.label.split('(')[0].trim();

            let friendlyDose = "";
            const halfSpoonCount = Math.round(roundedMl / 2.5);

            if (halfSpoonCount === 1) {
                friendlyDose = "Yarım Ölçek (2.5 ml)";
            } else if (halfSpoonCount === 2) {
                friendlyDose = "1 Tam Ölçek (5 ml)";
            } else if (halfSpoonCount === 3) {
                friendlyDose = "1.5 Ölçek (7.5 ml)";
            } else if (halfSpoonCount === 4) {
                friendlyDose = "2 Tam Ölçek (10 ml)";
            } else {
                friendlyDose = `Enjektör ile tam ${roundedMl} ml`;
            }

            document.getElementById('out-friendly-dose').innerText = friendlyDose;

            let verbalGuideText = "";
            if (drug.tType === "daily") {
                verbalGuideText = `Bu antibiyotiği hastaya ${drug.note} olacak şekilde, her seferinde tam ${friendlyDose.toLowerCase()} içiriniz. Tedaviyi hekiminizin önerdiği süre boyunca kesmeyiniz.`;
            } else {
                verbalGuideText = `Hastanın ağrısı veya ateşi olduğunda (tok karnına verilmesi önerilir), en az ${drug.gapHours} saat aralıklarla günde en fazla ${drug.freq} kez olmak üzere her seferinde ${friendlyDose.toLowerCase()} içiriniz. Semptomlar geçince kesilebilir.`;
            }
            document.getElementById('out-verbal-guide').innerText = verbalGuideText;
        }

        // Pano kopyalama işlemi
        function copyPrescription() {
            const weight = document.getElementById('weight').value;
            const prep = document.getElementById('out-prep-name').innerText;
            const dose = document.getElementById('out-friendly-dose').innerText;
            const verbal = document.getElementById('out-verbal-guide').innerText;

            const copyString = `KLİNİK HASTA KİLOSU: ${weight} kg\nPREPARAT: ${prep}\nTEK DOZ HACMİ: ${dose}\nVELİ TARİF ŞEKLİ: ${verbal}\n---\n*Pediatrik Dozaj Rehberi Asistanı Tarafından Oluşturulmuştur.`;

            const dummyArea = document.createElement("textarea");
            dummyArea.value = copyString;
            document.body.appendChild(dummyArea);
            dummyArea.select();
            document.execCommand('copy');
            document.body.removeChild(dummyArea);

            // Toast feedback
            const toast = document.createElement("div");
            toast.className = "fixed bottom-5 right-5 bg-slate-900 text-white border border-slate-700 px-4 py-3 rounded-xl shadow-2xl text-xs font-bold z-50 flex items-center gap-2 animate-pulse";
            toast.innerHTML = '<i class="fa-solid fa-circle-check text-emerald-400 text-sm"></i> Klinik reçete panoya kopyalandı!';
            document.body.appendChild(toast);
            setTimeout(() => { toast.remove(); }, 2500);
        }
    </script>
