    <!-- INTERAKTIF JS MOTORU -->
    <script>
        // İlaç Veritabanı
        const DB = {
            antibiotic: [
                { id: "aug_200", label: "Augmentin BID 200/28mg (Amok+Klav)", min: 25, max: 45, conc: 200, freq: 2, tType: "daily", note: "Sabah ve akşam (12 saat arayla)" },
